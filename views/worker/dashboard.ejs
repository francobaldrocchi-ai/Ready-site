<%- include('../partials/header',{title:'Dashboard worker'}) %>
<div class="grid two"><div class="card"><div class="section-title"><h2><%= worker.full_name %></h2><a class="btn secondary" href="/profile/worker/<%= currentUser.id %>">Profilo</a></div><p class="muted"><%= worker.city_area %> · <%= worker.roles %></p><p>Rating: <%= worker.avg_rating %> / 5 (<%= worker.review_count %>)</p></div><div class="card"><h2>Le tue candidature</h2><div class="list"><% myApplications.forEach(a=>{ %><div class="item"><strong><%= a.title %></strong><div class="small muted"><%= a.business_name %> · <%= a.shift_date %> <%= a.start_time %>-<%= a.end_time %></div><span class="badge"><%= a.status %></span>
<% if(a.status==='completed'){ %><form method="post" action="/reviews" class="small"><input type="hidden" name="shift_id" value="<%= a.shift_id %>"><input type="hidden" name="application_id" value="<%= a.id %>"><input type="hidden" name="to_user_id" value="<%= a.company_user_id %>"><input type="hidden" name="to_role" value="company"><label>Valuta azienda</label><select name="stars"><option>5</option><option>4</option><option>3</option><option>2</option><option>1</option></select><textarea name="comment" placeholder="Com'è andata?"></textarea><button>Invia recensione</button></form><% } %></div><% }) %></div></div></div>
<div class="spacer"></div>
<div class="card"><h2>Turni aperti</h2><div class="list"><% openShifts.forEach(s=>{ %><div class="item"><strong><%= s.title %></strong> <span class="badge"><%= s.role_needed %></span><div class="small muted"><%= s.business_name %> · <%= s.location %> · <%= s.shift_date %> <%= s.start_time %>-<%= s.end_time %> · €<%= s.pay_eur %></div><p><%= s.notes || '' %></p><div class="actions"><% if(!s.already_applied){ %><form method="post" action="/worker/apply/<%= s.id %>"><button>Candidati</button></form><% } else { %><span class="badge">Già candidato</span><% } %></div></div><% }) %></div></div>
<%- include('../partials/footer') %>
