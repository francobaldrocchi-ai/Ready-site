<%- include('../partials/header',{title:'Onboarding worker'}) %>
<%
  const labels = {
    waiter: 'Sala',
    runner: 'Runner',
    bar: 'Bar',
    kitchen_helper: 'Aiuto cucina',
    dishwasher: 'Lavapiatti'
  };
%>
<div class="card">
  <h2>Completa il tuo profilo worker</h2>
  <form method="post">
    <label>Nome e cognome</label>
    <input name="full_name" value="<%= profile.full_name || '' %>" required>

    <label>Telefono</label>
    <input name="phone" value="<%= profile.phone || '' %>" required>

    <label>Zona</label>
    <input name="city_area" value="<%= profile.city_area || '' %>" required>

    <label>Disponibilita</label>
    <input name="availability" value="<%= profile.availability || '' %>" placeholder="Es. pranzo, cena, weekend">

    <label>Mezzo di trasporto</label>
    <input name="transport_method" value="<%= profile.transport_method || '' %>">

    <label>Ruoli</label>
    <div class="checks">
      <% roleOptions.forEach((role) => { %>
        <label class="check">
          <input type="checkbox" name="roles" value="<%= role %>" <%= selectedRoles.includes(role) ? 'checked' : '' %>>
          <%= labels[role] || role %>
        </label>
      <% }) %>
    </div>

    <label>Anni di esperienza</label>
    <input name="years_experience" value="<%= profile.years_experience || '' %>">

    <label>Bio</label>
    <textarea name="bio"><%= profile.bio || '' %></textarea>

    <div class="actions">
      <button>Completa profilo</button>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
