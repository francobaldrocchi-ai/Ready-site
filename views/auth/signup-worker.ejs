<%- include('../partials/header',{title:'Registrazione worker'}) %>
<div class="grid two">
  <div class="card">
    <div class="eyebrow">Percorso worker</div>
    <h1>Crea il tuo account worker</h1>
    <p class="muted">Dopo la registrazione entrerai nel lead worker e potrai completare il tuo profilo Ready.</p>
    <form method="post" action="/register/worker">
      <label>Email</label><input name="email" type="email" required>
      <label>Password</label><input name="password" type="password" minlength="8" required>
      <div class="actions"><button>Registrati come worker</button><a class="btn secondary" href="/login">Ho già un account</a></div>
    </form>
  </div>
  <div class="card">
    <h2>Cosa succede dopo</h2>
    <div class="list">
      <div class="item"><strong>1. Entri nel lead worker</strong><div class="small muted">Ti registriamo subito nel sistema lead corretto</div></div>
      <div class="item"><strong>2. Completi l’onboarding</strong><div class="small muted">Ruoli, esperienza, zona e disponibilità</div></div>
      <div class="item"><strong>3. Accedi alla dashboard worker</strong><div class="small muted">Turni, candidature, storico e recensioni</div></div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
