<%- include('../partials/header',{title:'Dashboard azienda'}) %>
<div class="grid two"><div class="card"><div class="section-title"><h2><%= company.business_name %></h2><a class="btn secondary" href="/profile/company/<%= currentUser.id %>">Profilo</a></div><p class="muted"><%= company.city_area %> · <%= company.business_type %></p><p>Rating: <%= company.avg_rating %> / 5 (<%= company.review_count %>)</p><div class="actions"><a class="btn" href="/company/shifts/new">Nuovo turno</a></div></div><div class="card"><h2>Recensioni ricevute</h2><div class="list"><% reviews.forEach(r=>{ %><div class="item"><strong><%= r.stars %>/5</strong><div class="small muted"><%= r.reviewer_email %></div><p><%= r.comment %></p></div><% }) %></div></div></div>
<div class="spacer"></div>
<div class="grid two"><div class="card"><h2>I tuoi turni</h2><div class="list"><% shifts.forEach(s=>{ %><div class="item"><strong><%= s.title %></strong> <span class="badge"><%= s.status %></span><div class="small muted"><%= s.shift_date %> <%= s.start_time %>-<%= s.end_time %> · €<%= s.pay_eur %></div><p><%= s.notes||'' %></p><% if(s.status==='assigned'){ %><form method="post" action="/company/shifts/<%= s.id %>/complete"><button>Segna come completato</button></form><% } %></div><% }) %></div></div><div class="card"><h2>Candidature</h2><div class="list"><% applications.forEach(a=>{ %><div class="item"><strong><%= a.full_name %></strong> <span class="badge"><%= a.status %></span><div class="small muted"><%= a.title %> · <%= a.shift_date %> · <%= a.roles %></div><div class="actions"><% if(a.status==='pending'){ %><form method="post" action="/company/applications/<%= a.id %>/status"><input type="hidden" name="status" value="accepted"><button>Accetta</button></form><form method="post" action="/company/applications/<%= a.id %>/status"><input type="hidden" name="status" value="rejected"><button>Rifiuta</button></form><% } %>
<% if(a.status==='completed'){ %><form method="post" action="/reviews"><input type="hidden" name="shift_id" value="<%= a.shift_id %>"><input type="hidden" name="application_id" value="<%= a.id %>"><input type="hidden" name="to_user_id" value="<%= a.worker_user_id %>"><input type="hidden" name="to_role" value="worker"><select name="stars"><option>5</option><option>4</option><option>3</option><option>2</option><option>1</option></select><textarea name="comment" placeholder="Recensione worker"></textarea><button>Invia recensione</button></form><% } %></div></div><% }) %></div></div></div>
<%- include('../partials/footer') %>
