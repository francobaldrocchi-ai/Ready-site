<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> · Ready</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<header class="topbar">
  <a href="/" class="brand">Ready</a>
  <nav>
    <% if (currentUser) { %>
      <% if (currentUser.role==='admin') { %><a href="/admin/leads">Leads</a><% } %>
      <% if (currentUser.role==='worker') { %><a href="/worker/dashboard">Dashboard</a><% } %>
      <% if (currentUser.role==='company') { %><a href="/company/dashboard">Dashboard</a><% } %>
      <form method="post" action="/logout" class="inline"><button class="secondary">Logout</button></form>
    <% } else { %>
      <a href="/register/worker">Lavora come worker</a>
      <a href="/register/company">Lavora come azienda</a>
      <a href="/login">Login</a>
      <a href="/register" class="btn secondary">Registrati</a>
    <% } %>
  </nav>
</header>
<main class="container">
<% if (flash) { %><div class="flash <%= flash.type %>"><%= flash.message %></div><% } %>
<div class="notice-banner">Ready è in fase di pre-lancio: alcune funzioni complete saranno disponibili a breve.</div>
